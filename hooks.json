[
  {
    "id": "redeploy-kdash",
    "execute-command": "/docker/KDash/deploy.sh",
    "command-working-directory": "/docker/KDash",
    "trigger-rule": {
      "match": {
        "type": "value",
        "value": "refs/heads/main",
        "parameter": {
          "source": "payload",
          "name": "ref"
        }
      }
    }
  }
]